{
  "name": "invisiblejs",
  "version": "2.0.0",
  "description": "Embed hidden UTF-8 strings inside any text using invisible Unicode characters. Two codecs: variation-selector (Invisible) and zero-width 2-bit packed (ZeroWidth).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Duyzz/invisiblejs.git"
  },
  "homepage": "https://github.com/Duyzz/invisiblejs#readme",
  "bugs": {
    "url": "https://github.com/Duyzz/invisiblejs/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "steganography",
    "invisible",
    "unicode",
    "variation-selectors",
    "zero-width",
    "encode",
    "decode",
    "hidden",
    "zwsp"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.1.3"
  }
}
